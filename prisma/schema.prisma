// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma/client"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  email          String?   @unique
  phone          String?
  password       String?
  country        String?
  companyName    String?
  contactPerson  String?
  fullName       String?
  firstName      String?
  middleName     String?
  lastName       String?
  companyWebsite String?
  industry       String?
  type           UserTypeEnum?

  roleId         String
  role           Role     @relation(fields: [roleId], references: [id])
  service       Services[]
  client        Proposal[] @relation("clientProposal")
  projectReview ProjectReview[]
  Negotiation     Negotiate[] @relation("ClientNegotiation")

  createdAt      DateTime @default(now())
}

enum UserTypeEnum {
  INDIVIDUAL
  CORPORATE
}

model Role {
  id        String   @id @default(uuid())
  name      String   
  status    Status   @default(Active)
  createdAt DateTime @default(now())

  users     User[]
}


enum Status {
  Active
  InActive
}

//  enum status for propsoals stages

enum serviceStatus {
  ACTIVE
  INACTIVE
  REQUESTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProposalStatus {
  PENDING
  DRAFT
  SENT
  APPROVED
  DECLINED
  NEGOTIATING
 }


enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// Entry Point Service Models

model Services {
  id String @id @default(uuid())

  clientId String?
  client   User? @relation(fields: [clientId], references: [id])

  ServiceName String  
  Description String
  status serviceStatus

  Negotiation Negotiate[] @relation("Negotiated Service")

  proposal Proposal[] @relation("ServiceProposal")
  ProjectReview ProjectReview[] @relation("clientReview")
  DateCreated DateTime @default(now())
}

model Proposal {
  id String @id @default(uuid())

  serviceId String 
  clientId  String 

  // relations
  client User? @relation("clientProposal", fields: [clientId], references: [id])

  service Services @relation("ServiceProposal", fields: [serviceId], references: [id])
   
  proposal_status ProposalStatus

  createdAt DateTime @default(now())
}



// projects review enum
enum ReviewStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  NEGOTIATING
}

//  Clients to review what proposal Admin sent
model ProjectReview {
id  String @id @default(uuid())

service_id  String
client_id   String

service Services @relation("clientReview", fields: [service_id], references: [id])
client User @relation(fields: [client_id], references: [id])
Negotiate Negotiate[] @relation("Project Negotiation")



contract_id String?
scope String
deliverables  String
timeline    String
pricing     Int
status  ReviewStatus
termsAndConditions   String


}

model Negotiate {
  id   String @id  @default(uuid())
  clientId String
  client  User @relation( "ClientNegotiation", fields: [clientId], references: [id])
  
  proposal_id   String
  proposal    ProjectReview @relation("Project Negotiation", fields: [proposal_id], references: [id])

  serviceId  String
  service   Services  @relation("Negotiated Service", fields: [serviceId], references: [id])

  NegotiatingText     String 
}

