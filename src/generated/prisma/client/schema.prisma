// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma/client"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  phone          String
  password       String?
  country        String?
  companyName    String?
  contactPerson  String?
  fullName       String?
  firstName      String?
  middleName     String?
  lastName       String?
  companyWebsite String?
  industry       String?
  type           UserTypeEnum?

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  createdAt DateTime @default(now())
}

enum UserTypeEnum {
  INDIVIDUAL
  CORPORATE
}

model Role {
  id        String   @id @default(uuid())
  name      String // "Client", "Admin", etc
  status    Status   @default(Active)
  createdAt DateTime @default(now())

  users User[] // 🔥 one-to-many
}

enum Status {
  Active
  InActive
}
